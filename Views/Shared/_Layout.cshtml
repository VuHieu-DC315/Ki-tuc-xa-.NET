<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Ký túc xá</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/kitucxa.styles.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-brand {
            font-weight: 700;
        }

        .page-wrapper {
            background: #ffffff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 4px 18px rgba(0, 0, 0, 0.06);
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("User"))
                {
                    <a class="navbar-brand" asp-controller="Student" asp-action="Dashboard">
                        KTX Manager
                    </a>
                }
                else if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
                {
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                        KTX Manager
                    </a>
                }
                else
                {
                    <a class="navbar-brand" asp-controller="Account" asp-action="Login">
                        KTX Manager
                    </a>
                }

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 me-3">
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                                        Trang chủ
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Student" asp-action="Index">
                                        Quản lý sinh viên
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Room" asp-action="Index">
                                        Quản lý phòng
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Report" asp-action="Index">
                                        Báo cáo
                                    </a>
                                </li>
                            }
                            else if (User.IsInRole("User"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Student" asp-action="Dashboard">
                                        Trang sinh viên
                                    </a>
                                </li>
                            }
                        </ul>

                        <div class="d-flex align-items-center gap-2">
                            <span class="text-white small">
                                @User.Identity.Name
                            </span>

                            @if (User.IsInRole("Admin"))
                            {
                                <a class="btn btn-light btn-sm"
                                   asp-controller="Student"
                                   asp-action="Create">
                                    + Thêm sinh viên
                                </a>

                                <a class="btn btn-outline-light btn-sm"
                                   asp-controller="Room"
                                   asp-action="Create">
                                    + Thêm phòng
                                </a>
                            }

                            <a class="btn btn-outline-light btn-sm"
                               asp-controller="Account"
                               asp-action="Logout">
                                Đăng xuất
                            </a>
                        </div>
                    }
                    else
                    {
                        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">
                                    Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            <div class="page-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top text-muted py-3 bg-white">
        <div class="container">
            &copy; @DateTime.Now.Year - Hệ thống quản lý ký túc xá
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>