<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ký túc xá</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/kitucxa.styles.css" asp-append-version="true" />

    <style>
        html {
            font-size: 16px;
        }

        body {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }

        main {
            flex: 1;
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
        }

        .page-wrapper {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
        }

        .footer-custom {
            background-color: #ffffff;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">KTX Manager</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 me-3">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Student" asp-action="Index">Sinh viên</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Room" asp-action="Index">Phòng</a>
                        </li>
                    </ul>

                    <div class="d-flex">
                        <a class="btn btn-light btn-sm me-2" asp-controller="Student" asp-action="Create">+ Thêm sinh viên</a>
                        <a class="btn btn-outline-light btn-sm" asp-controller="Room" asp-action="Create">+ Thêm phòng</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            <div class="page-wrapper">
                @RenderBody()
            </div>
        </main>
    </div>

    <footer class="border-top footer-custom text-muted py-3 mt-auto">
        <div class="container d-flex justify-content-between align-items-center flex-wrap">
            <div>
                &copy; @DateTime.Now.Year - Hệ thống quản lý ký túc xá
            </div>
            <div>
                <a class="text-decoration-none me-3" asp-controller="Home" asp-action="Index">KTX Manager</a>
                <a class="text-decoration-none me-3" asp-controller="Student" asp-action="Index">Sinh viên</a>
                <a class="text-decoration-none" asp-controller="Room" asp-action="Index">Phòng</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>