@model kitucxa.Models.StudentDashboardVm

@{
    ViewData["Title"] = "Trang sinh viên";

    int myRoomCurrentCount = Model.MyRoom?.Students?.Count ?? 0;
    int myRoomCapacity = Model.MyRoom?.Capacity ?? 0;
    int myRoomAvailableCount = Math.Max(myRoomCapacity - myRoomCurrentCount, 0);
}

<div class="student-dashboard">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Trang sinh viên</h2>
            <div class="text-muted">
                Xin chào, <strong>@Model.Student.FullName</strong>
            </div>
        </div>

        <a class="btn btn-outline-danger btn-sm" asp-controller="Account" asp-action="Logout">
            Đăng xuất
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Phòng hiện tại</div>
                    <div class="fs-4 fw-bold">
                        @(Model.MyRoom != null ? Model.MyRoom.RoomNumber : "Chưa có phòng")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Số người trong phòng</div>
                    <div class="fs-4 fw-bold">
                        @(Model.MyRoom != null ? $"{myRoomCurrentCount}/{myRoomCapacity}" : "-")
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <div class="text-muted small">Chỗ còn trống</div>
                    <div class="fs-4 fw-bold">
                        @(Model.MyRoom != null ? myRoomAvailableCount.ToString() : "-")
                    </div>
                </div>
            </div>
        </div>
    </div>

    <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    type="button"
                    data-bs-toggle="tab"
                    data-bs-target="#my-room"
                    role="tab">
                Phòng của tôi
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    type="button"
                    data-bs-toggle="tab"
                    data-bs-target="#student-profile"
                    role="tab">
                Thông tin cá nhân
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    type="button"
                    data-bs-toggle="tab"
                    data-bs-target="#rooms"
                    role="tab">
                Danh sách phòng
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="my-room" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Phòng của tôi</h4>

                    @if (Model.MyRoom == null)
                    {
                        <div class="alert alert-warning mb-0">
                            Bạn chưa được xếp phòng. Hãy vào tab "Danh sách phòng" để đăng kí phòng.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle mb-0">
                                <tbody>
                                    <tr>
                                        <th style="width: 220px;">Số phòng</th>
                                        <td>@Model.MyRoom.RoomNumber</td>
                                    </tr>

                                    <tr>
                                        <th>Sức chứa</th>
                                        <td>@Model.MyRoom.Capacity</td>
                                    </tr>

                                    <tr>
                                        <th>Số sinh viên hiện tại</th>
                                        <td>@myRoomCurrentCount</td>
                                    </tr>

                                    <tr>
                                        <th>Chỗ còn trống</th>
                                        <td>@myRoomAvailableCount</td>
                                    </tr>

                                    <tr>
                                        <th>Trạng thái</th>
                                        <td>
                                            @if (myRoomAvailableCount > 0)
                                            {
                                                <span class="badge bg-success">Còn chỗ</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Đã đầy</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="student-profile" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Thông tin cá nhân</h4>

                    <div class="table-responsive">
                        <table class="table table-bordered align-middle mb-0">
                            <tbody>
                                <tr>
                                    <th style="width: 220px;">Mã sinh viên</th>
                                    <td>@Model.Student.Id</td>
                                </tr>

                                <tr>
                                    <th>Họ tên</th>
                                    <td>@Model.Student.FullName</td>
                                </tr>

                                <tr>
                                    <th>Giới tính</th>
                                    <td>@Model.Student.Gender</td>
                                </tr>

                                <tr>
                                    <th>Ngày sinh</th>
                                    <td>@Model.Student.DateOfBirth.ToString("dd/MM/yyyy")</td>
                                </tr>

                                <tr>
                                    <th>Số điện thoại</th>
                                    <td>@Model.Student.PhoneNumber</td>
                                </tr>

                                <tr>
                                    <th>Phòng</th>
                                    <td>
                                        @if (Model.Student.Room != null)
                                        {
                                            @Model.Student.Room.RoomNumber
                                        }
                                        else
                                        {
                                            <span class="text-muted">Chưa có phòng</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="rooms" role="tabpanel">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h4 class="mb-3">Danh sách phòng</h4>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Số phòng</th>
                                    <th>Sức chứa</th>
                                    <th>Số sinh viên hiện tại</th>
                                    <th>Chỗ còn trống</th>
                                    <th>Trạng thái</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var room in Model.Rooms)
                                {
                                    int currentCount = room.Students?.Count ?? 0;
                                    int availableCount = Math.Max(room.Capacity - currentCount, 0);

                                    bool hasRoom = Model.MyRoom != null;
                                    bool isMyRoom = hasRoom && room.Id == Model.MyRoom!.Id;
                                    bool isFull = availableCount <= 0;

                                    <tr class="@(isMyRoom ? "table-primary" : "")">
                                        <td>
                                            <strong>@room.RoomNumber</strong>

                                            @if (isMyRoom)
                                            {
                                                <span class="badge bg-primary ms-2">Phòng của tôi</span>
                                            }
                                        </td>

                                        <td>@room.Capacity</td>
                                        <td>@currentCount</td>
                                        <td>@availableCount</td>

                                        <td>
                                            @if (availableCount > 0)
                                            {
                                                <span class="badge bg-success">Còn chỗ</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Đã đầy</span>
                                            }
                                        </td>

                                        <td>
                                            @if (isMyRoom)
                                            {
                                                <button class="btn btn-secondary btn-sm" disabled>
                                                    Đang ở
                                                </button>
                                            }
                                            else if (isFull)
                                            {
                                                <button class="btn btn-secondary btn-sm" disabled>
                                                    Đã đầy
                                                </button>
                                            }
                                            else if (hasRoom)
                                            {
                                                <a class="btn btn-warning btn-sm"
                                                   asp-controller="Report_Room"
                                                   asp-action="Index"
                                                   asp-route-StudentId="@Model.Student.Id"
                                                   asp-route-OldRoomId="@Model.MyRoom!.Id"
                                                   asp-route-NewRoomId="@room.Id">
                                                    Đổi phòng
                                                </a>
                                            }
                                            else
                                            {
                                                <a class="btn btn-success btn-sm"
                                                   asp-controller="Report_Room"
                                                   asp-action="Index"
                                                   asp-route-StudentId="@Model.Student.Id"
                                                   asp-route-NewRoomId="@room.Id">
                                                    Đăng kí
                                                </a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>